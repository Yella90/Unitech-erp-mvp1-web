PORT=5000
JWT_SECRET=change-me
# Supabase / PostgreSQL
# Recommended: use the split variables below so the backend builds the connection string itself.
DATABASE_HOST=aws-0-region.pooler.supabase.com
DATABASE_PORT=5432
DATABASE_USER=postgres.username
DATABASE_PASSWORD=your-password
DATABASE_NAME=postgres
DATABASE_SSL=true

# Optional overrides if you prefer a single URL:
DATABASE_URL=
SUPABASE_DATABASE_URL=
POSTGRES_POOLER_URL=
POSTGRES_POOLER_UR=
